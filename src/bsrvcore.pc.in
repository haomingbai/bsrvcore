prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: @PROJECT_NAME@
Description: @BSRVCORE_PC_DESCRIPTION@
Version: @PROJECT_VERSION@
Libs: -L${libdir} -lbsrvcore
Libs.private: -lboost_system -lboost_url -lssl -lcrypto
Cflags: -I${includedir}
