prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: bsrvcore-c
Description: C bindings for bsrvcore
Version: @PROJECT_VERSION@
@BSRVCORE_C_PC_REQUIRES_PRIVATE_LINE@
Libs: -L${libdir} -lbsrvcore-c
Cflags: -I${includedir}
