@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

if(POLICY CMP0167)
  if(APPLE)
    cmake_policy(SET CMP0167 OLD)
  else()
    cmake_policy(SET CMP0167 NEW)
  endif()
endif()
if(APPLE)
  set(Boost_NO_BOOST_CMAKE ON)
endif()
find_dependency(Boost 1.75 REQUIRED COMPONENTS system url json program_options regex)
find_dependency(OpenSSL REQUIRED COMPONENTS SSL Crypto)

# Include the exported targets for consumers
include("${CMAKE_CURRENT_LIST_DIR}/bsrvcoreTargets.cmake")
