# Minimal Doxyfile template
PROJECT_NAME           = "@PROJECT_NAME@"
OUTPUT_DIRECTORY       = "@DOXYGEN_OUTPUT_DIR@"
CREATE_SUBDIRS         = YES
INPUT                  = @DOXYGEN_INPUT_DIRS@
RECURSIVE              = YES
EXTRACT_ALL            = NO
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
WARN_AS_ERROR          = YES
WARN_LOGFILE           = doxygen-warnings.log
EXCLUDE_SYMBOLS        = BSRVCORE_BSRVRUN_PLUGIN_EXPORT_H_
GENERATE_TREEVIEW      = YES
